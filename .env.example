###
# Example environment variables for Safe-URL-Check
# Copy this file to `.env` and populate real API keys for local development.
# Do NOT check your real `.env` into source control. Use Vercel/Heroku/GitHub Actions
# project settings to configure production secrets.
###

# Google Safe Browsing API key (required)
SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key_here

# Abuse/Threat intel providers (required)
OTX_API_KEY=your_alienvault_otx_api_key_here
URLHAUS_API_KEY=your_urlhaus_api_key_here

# Flask configuration (optional)
# FLASK_DEBUG=1
# HOST=0.0.0.0
# PORT=5000
# Environment variable configuration file for Safe URL Check application
# Safe URL Check Environment Variables

# Configuration for Google Safe Browsing API integration
# Google Safe Browsing API Key
# Obtain a free API key by visiting the Google Safe Browsing documentation
# Get your free API key at: https://developers.google.com/safe-browsing/v4/get-started
# This key enables threat detection for phishing and malware URLs
SAFE_BROWSING_API_KEY=your_api_key_here

# Instructions for using this configuration file
# Usage: Copy this file to .env and replace the placeholder values
# The .env file should never be committed to version control

# AlienVault OTX (optional) API Key for expanded intelligence
# Create an API key at https://otx.alienvault.com/ if you want OTX lookups
OTX_API_KEY=904ca41abbc2371407b10263d9e40521e401153ad8b475820964b83dacc5ec8a

